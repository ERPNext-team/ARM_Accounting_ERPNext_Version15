  "html": "<style>\r\n    @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap');\r\n    \r\n    .arm-premium-invoice {\r\n        font-family: 'Tajawal', sans-serif;\r\n        direction: rtl;\r\n        color: #111111;\r\n        background: #ffffff;\r\n        padding: 20px;\r\n    }\r\n\r\n    .arm-premium-invoice table {\r\n        width: 100%;\r\n        border-collapse: collapse;\r\n    }\r\n\r\n    /* الترويسة العلوية */\r\n    .premium-header {\r\n        border-bottom: 2px solid #000000;\r\n        padding-bottom: 20px;\r\n        margin-bottom: 40px;\r\n    }\r\n    \r\n    .invoice-title {\r\n        font-size: 32px;\r\n        font-weight: 800;\r\n        margin: 0;\r\n        color: #000000;\r\n        letter-spacing: -0.5px;\r\n    }\r\n    \r\n    .invoice-subtitle {\r\n        font-size: 14px;\r\n        color: #777777;\r\n        margin: 5px 0 0 0;\r\n        letter-spacing: 3px;\r\n        font-weight: 500;\r\n    }\r\n\r\n    /* بيانات العميل والمستند */\r\n    .meta-section {\r\n        margin-bottom: 40px;\r\n    }\r\n    \r\n    .meta-label {\r\n        font-size: 12px;\r\n        color: #888888;\r\n        margin-bottom: 5px;\r\n        font-weight: 500;\r\n    }\r\n    \r\n    .client-name {\r\n        font-size: 18px;\r\n        font-weight: 700;\r\n        margin: 0;\r\n    }\r\n    \r\n    .meta-data-table td {\r\n        padding-bottom: 8px;\r\n        font-size: 13px;\r\n    }\r\n\r\n    /* جدول البنود */\r\n    .modern-table {\r\n        margin-bottom: 40px;\r\n    }\r\n    \r\n    .modern-table th {\r\n        padding: 12px 5px;\r\n        border-bottom: 2px solid #000000;\r\n        font-size: 13px;\r\n        color: #555555;\r\n        font-weight: 700;\r\n    }\r\n    \r\n    .modern-table td {\r\n        padding: 16px 5px;\r\n        border-bottom: 1px solid #eeeeee;\r\n        vertical-align: top;\r\n    }\r\n    \r\n    .item-title {\r\n        font-size: 14px;\r\n        font-weight: 700;\r\n        color: #000000;\r\n    }\r\n    \r\n    .item-desc {\r\n        font-size: 12px;\r\n        color: #777777;\r\n        margin-top: 4px;\r\n        line-height: 1.5;\r\n    }\r\n\r\n    /* المجاميع */\r\n    .totals-table td {\r\n        padding: 12px 10px;\r\n        font-size: 14px;\r\n    }\r\n    \r\n    .total-final-row td {\r\n        border-top: 2px solid #000000;\r\n        font-size: 18px;\r\n        font-weight: 800;\r\n        padding-top: 15px;\r\n    }\r\n\r\n    /* الشروط والأحكام */\r\n    .premium-terms {\r\n        background-color: #fcfcfc;\r\n        border-right: 3px solid #000000;\r\n        padding: 20px;\r\n        font-size: 12px;\r\n        color: #555555;\r\n        margin-bottom: 60px;\r\n    }\r\n    \r\n    .premium-terms h4 {\r\n        margin: 0 0 10px 0;\r\n        color: #000000;\r\n        font-size: 14px;\r\n    }\r\n\r\n    /* التوقيعات */\r\n    .signature-box {\r\n        border-bottom: 1px solid #000000;\r\n        height: 60px;\r\n        margin-bottom: 10px;\r\n    }\r\n</style>\r\n\r\n<div class=\"arm-premium-invoice\">\r\n\r\n    <!-- الترويسة -->\r\n    <table class=\"premium-header\">\r\n        <tr>\r\n            <td style=\"width: 50%; vertical-align: middle;\">\r\n                <img src=\"{{ frappe.db.get_value('Company', doc.company, 'company_logo') or '/private/files/ARM_LOGO.webp' }}\" style=\"max-height: 70%;\" alt=\"ARM Logo\">\r\n            </td>\r\n            <td style=\"width: 50%; text-align: left; vertical-align: middle;\" dir=\"ltr\">\r\n                <h1 class=\"invoice-title\">مطالبة مالية</h1>\r\n                <p class=\"invoice-subtitle\">INVOICE</p>\r\n            </td>\r\n        </tr>\r\n    </table>\r\n\r\n    <!-- تفاصيل الفاتورة والعميل -->\r\n    <table class=\"meta-section\">\r\n        <tr>\r\n            <td style=\"width: 50%; vertical-align: top;\">\r\n                <div class=\"meta-label\">إلى السادة (Billed To):</div>\r\n                <h2 class=\"client-name\">{{ doc.customer_name }}</h2>\r\n                <div style=\"font-size: 13px; color: #555; margin-top: 8px;\">\r\n                    <strong>المشروع:</strong> {{ doc.project or 'غير محدد' }}<br>\r\n                    <strong>المرحلة:</strong> {{ doc.custom_design_phase or 'حسب العقد' }}\r\n                </div>\r\n            </td>\r\n            <td style=\"width: 50%; vertical-align: top;\">\r\n                <table class=\"meta-data-table\" dir=\"ltr\" style=\"width: 100%; text-align: left;\">\r\n                    <tr>\r\n                        <td style=\"color: #888; text-align: right; width: 50%;\">Invoice No:</td>\r\n                        <td style=\"font-weight: 700; text-align: right; width: 50%;\">{{ doc.name }}</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td style=\"color: #888; text-align: right;\">Date:</td>\r\n                        <td style=\"text-align: right;\">{{ doc.get_formatted(\"posting_date\") }}</td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td style=\"color: #888; text-align: right;\">Due Date:</td>\r\n                        <td style=\"text-align: right;\">{{ doc.get_formatted(\"due_date\") }}</td>\r\n                    </tr>\r\n                </table>\r\n            </td>\r\n        </tr>\r\n    </table>\r\n\r\n    <!-- جدول البنود -->\r\n    <table class=\"modern-table\">\r\n        <thead>\r\n            <tr>\r\n                <th style=\"text-align: right; width: 45%;\">البيان / Description</th>\r\n                <th style=\"text-align: center; width: 15%;\">الكمية / Qty</th>\r\n                <th style=\"text-align: center; width: 20%;\">السعر / Rate</th>\r\n                <th style=\"text-align: left; width: 20%;\" dir=\"ltr\">الإجمالي / Amount</th>\r\n            </tr>\r\n        </thead>\r\n        <tbody>\r\n            {% for row in doc.items %}\r\n            <tr>\r\n                <td style=\"text-align: right;\">\r\n                    <div class=\"item-title\">{{ row.item_name }}</div>\r\n                    <div class=\"item-desc\">{{ row.description }}</div>\r\n                </td>\r\n                <td style=\"text-align: center; font-size: 14px;\">{{ row.qty }}</td>\r\n                <!-- التصحيح هنا: استخدام get_formatted بدلاً من fmt_money -->\r\n                <td style=\"text-align: center; font-size: 14px;\">{{ row.get_formatted(\"rate\") }}</td>\r\n                <td style=\"text-align: left; font-size: 14px; font-weight: 700;\" dir=\"ltr\">{{ row.get_formatted(\"amount\") }}</td>\r\n            </tr>\r\n            {% endfor %}\r\n        </tbody>\r\n    </table>\r\n\r\n    <!-- المجاميع -->\r\n    <table style=\"width: 100%; margin-bottom: 50px;\">\r\n        <tr>\r\n            <td style=\"width: 50%;\"></td>\r\n            <td style=\"width: 50%;\">\r\n                <table class=\"totals-table\" dir=\"ltr\" style=\"width: 100%;\">\r\n                    <tr>\r\n                        <td style=\"color: #777; text-align: left;\">Subtotal</td>\r\n                        <!-- التصحيح هنا -->\r\n                        <td style=\"text-align: right;\">{{ doc.get_formatted(\"base_total\") }}</td>\r\n                    </tr>\r\n                    {% if doc.total_taxes_and_charges %}\r\n                    <tr>\r\n                        <td style=\"color: #777; text-align: left;\">Taxes & Fees</td>\r\n                        <td style=\"text-align: right;\">{{ doc.get_formatted(\"total_taxes_and_charges\") }}</td>\r\n                    </tr>\r\n                    {% endif %}\r\n                    <tr class=\"total-final-row\">\r\n                        <td style=\"text-align: left;\">Total Due</td>\r\n                        <td style=\"text-align: right;\">{{ doc.get_formatted(\"grand_total\") }}</td>\r\n                    </tr>\r\n                </table>\r\n            </td>\r\n        </tr>\r\n    </table>\r\n\r\n    <!-- الشروط والأحكام -->\r\n    <div class=\"premium-terms\">\r\n        <h4>الشروط والأحكام (Terms & Conditions)</h4>\r\n        {% if doc.terms %}\r\n            {{ doc.terms }}\r\n        {% else %}\r\n            <ul style=\"margin: 0; padding-right: 15px;\">\r\n                <li style=\"margin-bottom: 5px;\">يتم سداد الدفعات وفقاً للمراحل الهندسية المحددة مسبقاً (25% كدفعة مقدمة لكل مرحلة).</li>\r\n                <li>يُعد هذا المستند مطالبة مالية معتمدة من إدارة الحسابات في شركة آرم للعمارة والبناء ولا يعتد به كفاتورة ضريبية نهائية إلا بعد السداد.</li>\r\n            </ul>\r\n        {% endif %}\r\n    </div>\r\n\r\n    <!-- التوقيعات -->\r\n    <table style=\"width: 100%; text-align: center; margin-top: 40px;\">\r\n        <tr>\r\n            <td style=\"width: 40%;\">\r\n                <div class=\"signature-box\"></div>\r\n                <div style=\"font-size: 13px; color: #555; font-weight: 500;\">توقيع العميل / الاعتماد</div>\r\n            </td>\r\n            <td style=\"width: 20%;\"></td>\r\n            <td style=\"width: 40%;\">\r\n                <div class=\"signature-box\"></div>\r\n                <div style=\"font-size: 13px; color: #555; font-weight: 500;\">الختم المعتمد لشركة آرم</div>\r\n            </td>\r\n        </tr>\r\n    </table>\r\n\r\n</div>",
