  "html": "<style>\r\n    /* ARM Architecture & Construction Base Theme */\r\n    .print-format {\r\n        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\r\n        color: #111;\r\n        background: #fff;\r\n        font-size: 13px;\r\n        line-height: 1.5;\r\n    }\r\n    \r\n    /* Structural Header */\r\n    .header-container {\r\n        display: flex;\r\n        justify-content: space-between;\r\n        align-items: center;\r\n        border-bottom: 2px solid #000;\r\n        padding-bottom: 25px;\r\n        margin-bottom: 30px;\r\n    }\r\n    \r\n    .logo-container img {\r\n        max-width: 280px;\r\n        height: auto;\r\n    }\r\n    \r\n    .company-details {\r\n        text-align: right;\r\n    }\r\n    \r\n    .company-details h2 {\r\n        margin: 0 0 5px 0;\r\n        font-size: 24px;\r\n        font-weight: 600;\r\n        font-family: 'Tajawal', 'Cairo', sans-serif; /* Arabic support */\r\n        direction: rtl;\r\n    }\r\n    \r\n    .company-details .en-title {\r\n        font-size: 11px;\r\n        text-transform: uppercase;\r\n        letter-spacing: 1.5px;\r\n        color: #333;\r\n    }\r\n\r\n    /* Document Meta & Billing Info */\r\n    .invoice-header {\r\n        text-align: left;\r\n        margin-bottom: 20px;\r\n        text-transform: uppercase;\r\n        letter-spacing: 2px;\r\n        font-size: 18px;\r\n        font-weight: bold;\r\n    }\r\n\r\n    .info-grid {\r\n        display: flex;\r\n        justify-content: space-between;\r\n        margin-bottom: 40px;\r\n    }\r\n    \r\n    .info-box {\r\n        width: 48%;\r\n        border: 1px solid #000;\r\n        padding: 15px;\r\n    }\r\n    \r\n    .info-box h4 {\r\n        margin-top: 0;\r\n        margin-bottom: 10px;\r\n        font-size: 11px;\r\n        text-transform: uppercase;\r\n        border-bottom: 1px solid #eee;\r\n        padding-bottom: 5px;\r\n        color: #555;\r\n    }\r\n\r\n    /* Architectural Grid Tables */\r\n    table.blueprint-table {\r\n        width: 100%;\r\n        border-collapse: collapse;\r\n        margin-bottom: 40px;\r\n    }\r\n    \r\n    table.blueprint-table th, \r\n    table.blueprint-table td {\r\n        border: 1px solid #000;\r\n        padding: 12px;\r\n        text-align: left;\r\n    }\r\n    \r\n    table.blueprint-table th {\r\n        background-color: #f9f9f9;\r\n        text-transform: uppercase;\r\n        font-size: 11px;\r\n        letter-spacing: 1px;\r\n        font-weight: bold;\r\n    }\r\n\r\n    /* Financial Totals */\r\n    .totals-wrapper {\r\n        display: flex;\r\n        justify-content: flex-end;\r\n    }\r\n    \r\n    .totals-box {\r\n        width: 50%;\r\n        border: 1px solid #000;\r\n    }\r\n\r\n    .totals-table {\r\n        width: 100%;\r\n        border-collapse: collapse;\r\n    }\r\n\r\n    .totals-table td {\r\n        padding: 10px 15px;\r\n        border-bottom: 1px solid #000;\r\n    }\r\n    \r\n    .totals-table tr:last-child td {\r\n        border-bottom: none;\r\n    }\r\n\r\n    .totals-table .total-label {\r\n        text-transform: uppercase;\r\n        font-size: 11px;\r\n        font-weight: bold;\r\n    }\r\n\r\n    .totals-table .grand-total {\r\n        background-color: #000;\r\n        color: #fff;\r\n        font-weight: bold;\r\n        font-size: 14px;\r\n    }\r\n\r\n    /* Footer */\r\n    .footer {\r\n        margin-top: 50px;\r\n        text-align: center;\r\n        font-size: 10px;\r\n        border-top: 1px solid #000;\r\n        padding-top: 15px;\r\n        text-transform: uppercase;\r\n        letter-spacing: 1px;\r\n    }\r\n</style>\r\n\r\n<div class=\"print-format\">\r\n    <!-- Header with Logo -->\r\n    <div class=\"header-container\">\r\n        <div class=\"logo-container\">\r\n            <!-- Ensure your logo is uploaded in the Company record in ERPNext -->\r\n            <img src=\"{{ frappe.db.get_value('Company', doc.company, 'company_logo') or '' }}\" alt=\"ARM Logo\">\r\n        </div>\r\n        <div class=\"company-details\">\r\n            <h2>شركة آرم للعمارة والبناء</h2>\r\n            <div class=\"en-title\">For Architecture and Construction</div>\r\n        </div>\r\n    </div>\r\n\r\n    <div class=\"invoice-header\">\r\n        <!-- Change to Quotation or Receipt depending on the DocType -->\r\n        Invoice\r\n    </div>\r\n\r\n    <!-- Client & Document Info -->\r\n    <div class=\"info-grid\">\r\n        <div class=\"info-box\">\r\n            <h4>Billed To</h4>\r\n            <strong>{{ doc.customer_name }}</strong><br>\r\n            {% if doc.address_display %}\r\n                {{ doc.address_display }}\r\n            {% endif %}\r\n            {% if doc.contact_display %}\r\n                <br>ATTN: {{ doc.contact_display }}\r\n            {% endif %}\r\n        </div>\r\n        \r\n        <div class=\"info-box\">\r\n            <h4>Document Details</h4>\r\n            <table style=\"width: 100%; font-size: 12px;\">\r\n                <tr>\r\n                    <td><strong>Invoice No:</strong></td>\r\n                    <td style=\"text-align: right;\">{{ doc.name }}</td>\r\n                </tr>\r\n                <tr>\r\n                    <td><strong>Date:</strong></td>\r\n                    <td style=\"text-align: right;\">{{ doc.get_formatted(\"posting_date\") }}</td>\r\n                </tr>\r\n                {% if doc.due_date %}\r\n                <tr>\r\n                    <td><strong>Due Date:</strong></td>\r\n                    <td style=\"text-align: right;\">{{ doc.get_formatted(\"due_date\") }}</td>\r\n                </tr>\r\n                {% endif %}\r\n                {% if doc.project %}\r\n                <tr>\r\n                    <td><strong>Project:</strong></td>\r\n                    <td style=\"text-align: right;\">{{ doc.project }}</td>\r\n                </tr>\r\n                {% endif %}\r\n            </table>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Line Items Table -->\r\n    <table class=\"blueprint-table\">\r\n        <thead>\r\n            <tr>\r\n                <th style=\"width: 5%; text-align: center;\">#</th>\r\n                <th style=\"width: 45%;\">Service / Description</th>\r\n                <th style=\"width: 10%; text-align: right;\">Qty</th>\r\n                <th style=\"width: 20%; text-align: right;\">Rate</th>\r\n                <th style=\"width: 20%; text-align: right;\">Amount</th>\r\n            </tr>\r\n        </thead>\r\n        <tbody>\r\n            {% for item in doc.items %}\r\n            <tr>\r\n                <td style=\"text-align: center;\">{{ loop.index }}</td>\r\n                <td>\r\n                    <strong>{{ item.item_name }}</strong>\r\n                    {% if item.description %}\r\n                        <br><span style=\"font-size: 11px; color: #555;\">{{ item.description }}</span>\r\n                    {% endif %}\r\n                </td>\r\n                <td style=\"text-align: right;\">{{ item.qty }}</td>\r\n                <td style=\"text-align: right;\">{{ item.get_formatted(\"rate\") }}</td>\r\n                <td style=\"text-align: right;\">{{ item.get_formatted(\"amount\") }}</td>\r\n            </tr>\r\n            {% endfor %}\r\n        </tbody>\r\n    </table>\r\n\r\n    <!-- Totals -->\r\n    <div class=\"totals-wrapper\">\r\n        <div class=\"totals-box\">\r\n            <table class=\"totals-table\">\r\n                <tr>\r\n                    <td class=\"total-label\">Subtotal</td>\r\n                    <td style=\"text-align: right;\">{{ doc.get_formatted(\"total\") }}</td>\r\n                </tr>\r\n                \r\n                {% for tax in doc.taxes %}\r\n                <tr>\r\n                    <td class=\"total-label\" style=\"font-size: 10px; color: #555;\">{{ tax.description }}</td>\r\n                    <td style=\"text-align: right;\">{{ tax.get_formatted(\"tax_amount\") }}</td>\r\n                </tr>\r\n                {% endfor %}\r\n                \r\n                {% if doc.discount_amount %}\r\n                <tr>\r\n                    <td class=\"total-label\">Discount</td>\r\n                    <td style=\"text-align: right;\">- {{ doc.get_formatted(\"discount_amount\") }}</td>\r\n                </tr>\r\n                {% endif %}\r\n                \r\n                <tr>\r\n                    <td class=\"total-label grand-total\">Grand Total</td>\r\n                    <td class=\"grand-total\" style=\"text-align: right;\">{{ doc.get_formatted(\"grand_total\") }}</td>\r\n                </tr>\r\n            </table>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Note / Terms -->\r\n    {% if doc.terms %}\r\n    <div style=\"margin-top: 30px; font-size: 11px;\">\r\n        <strong>Terms & Conditions:</strong><br>\r\n        {{ doc.terms }}\r\n    </div>\r\n    {% endif %}\r\n\r\n    <!-- Footer -->\r\n    <div class=\"footer\">\r\n        شركة آرم للعمارة والبناء | ARM FOR ARCHITECTURE AND CONSTRUCTION<br>\r\n        Tripoli, Libya\r\n    </div>\r\n</div>",
